# ----------------------------------------------------------------------------
# Meroos environment configuration
#
# Copy to `.env` (`cp .env.example .env`) and fill in real values. This file is
# consumed by docker-compose for both variable substitution and as the backend
# container's env_file.
# ----------------------------------------------------------------------------

# === Core Django ===
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# When DEBUG=False, Django redirects HTTP->HTTPS by default. Set this to False
# if TLS is terminated upstream or for plain-HTTP testing (e.g. the bundled
# nginx on :8080). Leave True in real production with HTTPS.
SECURE_SSL_REDIRECT=False

# === Database (Postgres) ===
# In docker-compose, ENGINE/HOST/PORT are set automatically; these three are
# shared with the postgres container.
DATABASE_NAME=meroos_db
DATABASE_USER=meroos_user
DATABASE_PASSWORD=change-me-too
# For running the backend WITHOUT docker, also set:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# === Redis (channels, cache, celery) ===
# Set automatically in docker-compose; only needed for non-docker runs.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# === CORS ===
# Add the origin your SPA is served from. Behind the bundled nginx proxy the
# app is same-origin, so this mainly matters if you split the frontend out.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# === JWT lifetimes (minutes) ===
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# === Email ===
# Default backend just prints to the console. For real delivery, switch to SMTP:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@meroos.com

# === Compose ===
# Host port the app is published on (maps to nginx :80).
FRONTEND_PORT=8080
